{
  "name": "depnews",
  "version": "0.1.0",
  "description": "Digests the changelogs of every package that moved in your lockfile diff, read straight from node_modules. No API calls, no bot.",
  "author": "JaydenCJ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "depnews": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "docs/formats.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "changelog",
    "lockfile",
    "dependencies",
    "diff",
    "digest",
    "code-review",
    "offline",
    "npm"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/depnews.git"
  },
  "homepage": "https://github.com/JaydenCJ/depnews#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/depnews/issues"
  }
}
